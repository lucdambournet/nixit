VITE_SUPABASE_URL=<YOUR_SUPABASE_URL>
VITE_SUPABASE_ANON_KEY=<YOUR_SUPABASE_ANON_KEY>
SUPABASE_SERVICE_ROLE_KEY=<YOUR_SUPABASE_SERVICE_ROLE_KEY>

# Web Push (#51). Generate with `npx web-push generate-vapid-keys`.
# VITE_VAPID_PUBLIC_KEY is safe to expose to the client; the matching
# VAPID_PRIVATE_KEY must only ever live server-side, as a Supabase Edge
# Function secret (`supabase secrets set VAPID_PRIVATE_KEY=... VAPID_PUBLIC_KEY=...`),
# never in this file or committed anywhere.
VITE_VAPID_PUBLIC_KEY=<YOUR_VAPID_PUBLIC_KEY>